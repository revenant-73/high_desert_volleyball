---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '../components/Navbar';
import { Footer } from '../components/Footer';
import { PageHeader } from '../components/PageHeader';
import { MapPin, Info, AlertTriangle } from "lucide-react";
import { getVenues, getSiteConfig } from '../lib/keystatic';

const venues = await getVenues();
const siteConfig = await getSiteConfig();

if (!siteConfig) {
  throw new Error('Site configuration not found');
}
---

<Layout title={`Site Rules & Regulations | ${siteConfig.shortName}`}>
	<main class="min-h-screen bg-gray-950">
		<Navbar client:load siteConfig={siteConfig} />
		<PageHeader 
			title="Site Rules & Regulations" 
			subtitle="These rules are set by each individual site and must be enforced to ensure continued access."
		/>
		
		<div class="max-w-5xl mx-auto py-16 px-4">
			<div class="bg-blue-900/20 border border-blue-800/50 rounded-3xl p-8 mb-12 flex gap-6 items-start">
				<AlertTriangle className="h-8 w-8 text-blue-500 flex-shrink-0" />
				<div>
					<h3 className="text-xl font-bold text-white mb-2">Important Notice</h3>
					<p className="text-gray-400 leading-relaxed text-sm">
						Questions about site regulations should be sent to your Club Director. HDVL enforces these rules to maintain our facility agreements.
					</p>
				</div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				{venues.map((venue) => (
					<div className="bg-gray-900 rounded-3xl p-8 shadow-sm border border-gray-800 hover:border-gray-700 transition-colors">
						<div className="flex items-start justify-between mb-6">
							<div className="bg-blue-900/30 p-3 rounded-2xl">
								<MapPin className="h-6 w-6 text-blue-500" />
							</div>
						</div>
						
						<h2 className="text-xl font-bold text-white mb-2">{venue.name}</h2>
						<p className="text-sm text-gray-500 mb-6 flex items-center gap-2">
							{venue.address}
						</p>

						<div className="space-y-4">
							<h3 className="text-xs font-bold text-gray-500 uppercase tracking-wider flex items-center gap-2">
								<Info className="h-3 w-3" /> Facility Guidelines
							</h3>
							<ul className="space-y-3">
								{venue.rules.map((rule) => (
									<li className="text-sm text-gray-400 leading-relaxed pl-4 border-l-2 border-blue-900/50">
										{rule}
									</li>
								))}
							</ul>
						</div>
					</div>
				))}
			</div>
		</div>
		<Footer siteConfig={siteConfig} />
	</main>
</Layout>
