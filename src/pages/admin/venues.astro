---
import Layout from '../../layouts/Layout.astro';
import VenueManager from '../../components/admin/VenueManager';
import { getVenues } from '../../lib/db';

const venues = await getVenues();
---

<Layout title="Manage Venues | HDVL Admin">
  <main class="min-h-screen bg-zinc-950 text-white p-8">
    <div class="max-w-6xl mx-auto">
      <header class="flex items-center gap-4 mb-8">
        <a href="/admin" class="text-zinc-500 hover:text-white transition-colors">
          ← Dashboard
        </a>
        <h1 class="text-3xl font-bold">Manage Venues</h1>
      </header>

      <VenueManager client:load initialVenues={venues} />
    </div>
  </main>
</Layout>
