---
import Layout from '../../layouts/Layout.astro';
import EventManager from '../../components/admin/EventManager';
import { getEvents } from '../../lib/db';

const events = await getEvents();
---

<Layout title="Manage Events | HDVL Admin">
  <main class="min-h-screen bg-zinc-950 text-white p-8">
    <div class="max-w-6xl mx-auto">
      <header class="flex items-center gap-4 mb-8">
        <a href="/admin" class="text-zinc-500 hover:text-white transition-colors">
          ← Dashboard
        </a>
        <h1 class="text-3xl font-bold">Manage Events</h1>
      </header>

      <EventManager client:load initialEvents={events} />
    </div>
  </main>
</Layout>
